# Level 6 runs on YOUR Gemini quota. Pick ONE (the key wins if both are set).

# ── Path A · AI Studio (simplest) ── free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Path B · Vertex AI (your GCP project) ── leave GEMINI_API_KEY empty and run:
#   gcloud auth application-default login
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=global

# Optional
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_EMBED_MODEL=gemini-embedding-001
