# Level 6 needs a real Google Cloud project (Memory Bank runs on Vertex AI Agent Engine).
# Auth once:  gcloud auth application-default login

GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=True

# Created by `uv run python setup_engine.py` (idempotent — reuses by display name):
AGENT_ENGINE_ID=

# Optional
# MEMORY_ENGINE_NAME=multimodal-levels-memory
# DEMO_USER_ID=vega-7
