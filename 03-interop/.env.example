# Level 3 runs on YOUR quota: Vertex (the dispatcher's reasoning) + NVIDIA NIM (the remote Architect).

# ── Vertex AI (dispatcher LLM) ── gcloud auth application-default login, then:
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=True
# OR AI Studio:  # GOOGLE_API_KEY=

# ── NVIDIA NIM — the remote Architect's brain ── free key at https://build.nvidia.com
NVIDIA_API_KEY=nvapi-...
# ARCHITECT_MODEL=meta/llama-3.1-8b-instruct

# ── The remote Architect's address ──
# Local: start it with `uv run python -m architect.main` (PORT=8790).
# Real boundary: deploy it to its OWN Cloud Run host and point this at that URL.
ARCHITECT_URL=http://localhost:8790
