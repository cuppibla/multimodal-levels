# ADK reads these directly. Pick ONE path (the API key wins).

# ── AI Studio (simplest) ── free key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=False

# ── Vertex AI (your GCP project) ── leave GOOGLE_API_KEY empty, run `gcloud auth application-default login`:
# GOOGLE_GENAI_USE_VERTEXAI=True
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=global
