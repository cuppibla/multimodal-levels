# Level 2 runs on real Google Cloud: Vertex AI + BigQuery + Cloud Storage + two MCP servers.
# Auth once:  gcloud auth application-default login

GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=True

# The custom Location Analyzer MCP server (run locally, or a Cloud Run URL)
MCP_SERVER_URL=http://localhost:8788

# Optional
# GCS_BUCKET=your-project-id-multimodal-levels
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# VEO_MODEL=veo-3.0-generate-001
# VEO_LOCATION=us-central1

# (The old TS demo under src/ can still run on an AI Studio key: GEMINI_API_KEY=…)
