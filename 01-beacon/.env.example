# Level 1 runs on YOUR Gemini quota.

# ── Vertex AI (the workshop path) ── run `gcloud auth application-default login`, then:
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=True

# ── OR: AI Studio ── free key at https://aistudio.google.com/apikey (takes precedence if set)
# GOOGLE_API_KEY=

# Models (slide: "The model IDs move" — 2.5-flash-image sunsets Oct 2026; same API, new ID)
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image     # → gemini-3.1-flash-image / gemini-3-pro-image
# VEO_MODEL=veo-3.1-generate-preview
