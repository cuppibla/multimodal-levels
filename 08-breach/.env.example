# Level 8 runs on NVIDIA NIM (the agent + both rails) + Vertex (the sentinel ADK agent).

# ── NVIDIA NIM — the NOVA agent and both rail classifiers ── free key at https://build.nvidia.com
NVIDIA_API_KEY=nvapi-...
# BREACH_AGENT_MODEL=meta/llama-3.1-8b-instruct
# BREACH_RAIL_MODEL=meta/llama-3.1-8b-instruct

# ── Vertex AI (the sentinel ADK agent in run_mission.py) ── gcloud auth application-default login, then:
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=True
# AGENT_MODEL=gemini-2.5-flash

# Note: verify.py needs only NVIDIA_API_KEY — the deterministic gate never calls Vertex.
