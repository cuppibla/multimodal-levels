# Level 4 runs on YOUR quota: Vertex (the agent's reasoning) + NVIDIA NeMo Retriever (embeddings) + Neo4j.

# ── Vertex AI (the agent LLM) ── run `gcloud auth application-default login`, then:
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=True
# OR AI Studio (takes precedence if set):
# GOOGLE_API_KEY=

# ── NVIDIA NeMo Retriever (the embeddings — "find where to look") ──
# Free key at https://build.nvidia.com
NVIDIA_API_KEY=nvapi-...
# NEMO_EMBED_MODEL=nvidia/nv-embedqa-e5-v5     # 1024-dim; asymmetric query/passage

# ── Neo4j (the survivor graph — "how things connect") ──
# Local: docker run -d -p 7687:7687 -p 7474:7474 -e NEO4J_AUTH=neo4j/survivornet neo4j:5
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=survivornet
