# Level 7 runs on YOUR project: Vertex (operator agent) + NVIDIA NIM (worker plans) + real Cloud Pub/Sub.

# ── Vertex AI (operator agent) ── gcloud auth application-default login, then:
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=True

# ── NVIDIA NIM — worker-B plans the formation ── free key at https://build.nvidia.com
NVIDIA_API_KEY=nvapi-...
# OPS_MODEL=meta/llama-3.1-8b-instruct

# Real Cloud Pub/Sub uses GOOGLE_CLOUD_PROJECT (pubsub.googleapis.com enabled).
# For a LOCAL emulator instead: gcloud beta emulators pubsub start, then set:
# PUBSUB_EMULATOR_HOST=localhost:8085
# PUBSUB_PROJECT=wbh-local
