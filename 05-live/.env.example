# Level 5 runs on YOUR Gemini quota. Live models drift by path/region — the module probes for one that opens.

# ── Path A · AI Studio (simplest) ── free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Path B · Vertex AI (your GCP project) ── leave GEMINI_API_KEY empty and run:
#   gcloud auth application-default login
# GOOGLE_CLOUD_PROJECT=your-project-id
# GEMINI_LIVE_LOCATION=us-central1

# Pin a specific Live model if the probe can't find one on your project/region:
# GEMINI_LIVE_MODEL=gemini-2.0-flash-live-001
